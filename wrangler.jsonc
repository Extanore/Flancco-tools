{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "flancco-tools-v2",
  "compatibility_date": "2026-04-21",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
