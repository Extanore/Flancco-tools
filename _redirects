# =============================================================
# Cloudflare Pages — URL routing
# =============================================================
# Volgorde telt: meest-specifiek eerst. 200 = rewrite (URL blijft),
# 301 = redirect (URL wijzigt). 301! = force (overschrijf bestaande).

# --- Legacy GitHub Pages compat: /Flancco-tools/* paden wegpoetsen
/Flancco-tools/*                             /:splat                             301!

# --- Subdomain: calculator.flancco-platform.be
# Partner-specifieke paden (/novectra, /cwsolar, /flancco) blijven direct onder root
# Root van calculator-subdomain toont generic calculator
https://calculator.flancco-platform.be/      /calculator/                        200
https://calculator.flancco-platform.be/novectra/*    /novectra/:splat           200
https://calculator.flancco-platform.be/cwsolar/*     /cwsolar/:splat            200
https://calculator.flancco-platform.be/flancco/*     /flancco/:splat            200
https://calculator.flancco-platform.be/calculator/*  /calculator/:splat         200
https://calculator.flancco-platform.be/*     /calculator/:splat                  200

# --- Subdomain: app.flancco-platform.be
# Serveert admin + partner dashboard + portal vanuit /admin/ en /portal/
https://app.flancco-platform.be/admin/*      /admin/:splat                       200
https://app.flancco-platform.be/portal/*     /portal/:splat                      200
https://app.flancco-platform.be/privacy/*    /privacy/:splat                     200
https://app.flancco-platform.be/voorwaarden/*  /voorwaarden/:splat               200
https://app.flancco-platform.be/             /admin/                             302
https://app.flancco-platform.be/*            /admin/:splat                       200

# --- Apex + www → canonical app subdomain
https://flancco-platform.be/*                https://app.flancco-platform.be/:splat    301!
https://www.flancco-platform.be/*            https://app.flancco-platform.be/:splat    301!

# --- SPA fallback voor admin (hash-based routing)
/admin/*                                     /admin/index.html                   200
